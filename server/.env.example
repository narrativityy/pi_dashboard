PORT=3001
SESSION_SECRET=a-long-random-string

# Auth mode: "static" or "pam"
# static — username/password set below
# pam    — authenticates against real Linux user accounts on the host
AUTH_MODE=static

# Only used when AUTH_MODE=static
DASHBOARD_USER=youruser
DASHBOARD_PASS=yourpassword

# Comma-separated list of systemd services shown in the service manager
MANAGED_SERVICES=pi-dashboard,ssh
